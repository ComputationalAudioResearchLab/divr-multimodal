{
  "name": "divr-multimodel",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/home/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "ms-python.python",
        "hediet.vscode-drawio",
        "ms-toolsai.tensorboard"
      ]
    }
  },
  "shutdownAction": "none",
  "onCreateCommand": "export PIPENV_CUSTOM_VENV_NAME=divr-multimodel; pipenv install --site-packages --dev"
}
